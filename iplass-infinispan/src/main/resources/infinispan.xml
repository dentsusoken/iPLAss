<?xml version="1.0" encoding="UTF-8"?>
<infinispan
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="urn:infinispan:config:10.1 https://infinispan.org/schemas/infinispan-config-10.1.xsd"
      xmlns="urn:infinispan:config:10.1">
    <jgroups>
        <stack-file name="jgroups-udb" path="jg-udp.xml"/>
    </jgroups>

    <threads/>
    <cache-container default-cache="___defaultcache">
        <transport cluster="iPLAssInfinispanCluster" stack="jgroups-udb"/>
        <!-- バージョン 10.0 対応 -->
        <serialization marshaller="org.infinispan.commons.marshall.JavaSerializationMarshaller">
            <white-list>
            	<!-- TODO この設定は後から変更できるように -->
                <class>java.lang.invoke.SerializedLambda</class>
                <regex>^(\[L|)java\.(lang|util|sql)\..*(;|)$</regex>
                <regex>^(\[L|)org\.iplass\.mtp\.impl\.(cluster|cache\.store|infinispan)\..*(;|)$</regex>
            </white-list>
        </serialization>
        <jmx duplicate-domains="true"/>
        <distributed-cache owners="2" segments="32" mode="SYNC" remote-timeout="60000" name="___defaultcache">
            <transaction mode="NONE"/>
<!--        	<store-as-binary keys="true" values="false"/>-->
            <memory>
                <object/>
            </memory>
        </distributed-cache>
        <distributed-cache owners="2" segments="32" mode="SYNC" remote-timeout="60000" name="cubedata">
            <transaction mode="NONE"/>
            <expiration max-idle="6000000"/>
            <persistence passivation="true">
            	<!-- バージョン 10.0 へ上げた際、以下だと、 D:\temp-0, D:\temp-1 .... D:\temp-30 とディレクトリが作成される -->
                <!-- <file-store fetch-state="true" purge="true" path="${java.io.tmpdir}"/> --> 
            	<!-- バージョン 10.0 対応。バージョン 10.1 へ上げた際、「ISPN000558: The store location '${java.io.tmpdir}/cubedata/0' is not a child of the global persistent location '${EXECUTION_PATH}'」。ファイル位置は実行ディレクトリ以下にする必要がある。 -->
                <!-- <file-store fetch-state="true" purge="true" path="${java.io.tmpdir}/cubedata"/>  -->
                <!-- バージョン 10.1 対応 -->
                <file-store fetch-state="true" purge="true" path="./infinispan/cubedata"/> 
            </persistence>
            <memory>
                <object size="128"/>
            </memory>
        </distributed-cache>
        <local-cache name="local">
            <transaction mode="NONE"/>
            <memory>
                <object/>
            </memory>
        </local-cache>
        <replicated-cache mode="SYNC" remote-timeout="60000" name="replication">
            <transaction mode="NONE"/>
<!--        	<store-as-binary keys="true" values="false"/>-->
            <memory>
                <object/>
            </memory>
        </replicated-cache>
        <invalidation-cache mode="SYNC" remote-timeout="60000" name="invalidation">
            <transaction mode="NONE"/>
<!--        	<store-as-binary keys="true" values="false"/>-->
            <memory>
                <object/>
            </memory>
        </invalidation-cache>
        <distributed-cache owners="2" segments="32" mode="SYNC" remote-timeout="60000" name="distribution">
            <transaction mode="NONE"/>
<!--        	<store-as-binary keys="true" values="false"/>-->
            <memory>
                <object/>
            </memory>
        </distributed-cache>
    </cache-container>
</infinispan>
